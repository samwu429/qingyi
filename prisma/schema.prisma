// Prisma schema for the Qingyi Media platform.
// Persists administrator credentials, signed streamers, blog content, and
// editable site settings so that all public content is data-driven.
// 青意传媒平台的 Prisma 数据模型：存储管理员凭证、签约主播、博客内容与可编辑站点设置，
// 使前台内容完全由数据驱动。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Publication lifecycle shared by streamers and blog posts.
// 主播与博客共用的发布生命周期状态。
enum PublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Authoring format for a blog post body: Markdown (default) or free-form
// HTML/CSS for rich layouts, embedded SVG, long images, and PDF embeds.
// 博客正文的撰写格式：Markdown（默认）或自由 HTML/CSS（用于富排版、内嵌 SVG、长图与 PDF 嵌入）。
enum PostFormat {
  MARKDOWN
  HTML
}

// Administrator account authorised to manage all back-office content.
// 拥有后台内容管理权限的管理员账户。
model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

// Signed streamer profile presented in the guild roster.
// Bio supports the same Markdown / HTML authoring formats as blog posts
// (long images, SVG, PDF embeds via the HTML format).
// 公会主播名录中展示的签约主播档案。
// 简介与资讯相同，支持 Markdown / HTML（HTML 可嵌长图、SVG、PDF）。
model Streamer {
  id           String            @id @default(cuid())
  slug         String            @unique
  name         String
  tagline      String?
  bio          String?
  bioFormat    PostFormat        @default(MARKDOWN)
  avatarUrl    String?
  coverUrl     String?
  platform     String?
  platformUrl  String?
  category     String?
  tags         String[]          @default([])
  followers    Int               @default(0)
  socials      Json?
  status       PublicationStatus @default(PUBLISHED)
  featured     Boolean           @default(false)
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  metrics      StreamerMetric[]

  @@index([status, featured])
  @@index([sortOrder])
  @@map("streamers")
}

// Time-series performance record for a streamer. Only the latest fan count is
// surfaced publicly (mirrored onto Streamer.followers); the rest stay internal.
// 主播运营数据记录。前台仅展示最新粉丝数（同步到 Streamer.followers）；其余为内部指标。
model StreamerMetric {
  id          String   @id @default(cuid())
  streamerId  String
  streamer    Streamer @relation(fields: [streamerId], references: [id], onDelete: Cascade)
  period      String
  followers   Int      @default(0)
  income      Int      @default(0)
  /// Live duration for the period, in minutes.
  /// 该周期开播时长（分钟）。
  liveMinutes Int      @default(0)
  viewers     Int      @default(0)
  comments    Int      @default(0)
  likes       Int      @default(0)
  /// Douyin “音浪” (gift currency) earned in the period.
  /// 该周期收获音浪。
  yinlang     Int      @default(0)
  note        String?
  recordedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([streamerId, recordedAt])
  @@map("streamer_metrics")
}

// News and dynamic blog entry authored from the admin panel.
// 由后台撰写的资讯与动态博客文章。
model BlogPost {
  id          String            @id @default(cuid())
  slug        String            @unique
  title       String
  excerpt     String?
  content     String
  format      PostFormat        @default(MARKDOWN)
  coverUrl    String?
  author      String?
  tags        String[]          @default([])
  status      PublicationStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status, publishedAt])
  @@map("blog_posts")
}

// Flexible key/value store for editable page copy such as hero text and stats.
// 灵活的键值存储，用于可编辑的页面文案（如首页标语与统计数据）。
model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// Binary image asset uploaded from the admin panel. Stored in Postgres so
// files survive Render's ephemeral disk (Cloudinary is still preferred when set).
// 后台上传的图片二进制资源，存入 Postgres，避免 Render 瞬时磁盘丢失文件
//（若已配置 Cloudinary 则仍优先走云端）。
model MediaAsset {
  id          String   @id @default(cuid())
  mimeType    String
  byteSize    Int
  data        Bytes
  createdAt   DateTime @default(now())

  @@map("media_assets")
}

// Recruitment / join-us enquiry submitted from the public site.
// 前台「加入我们」页提交的招募留言。
model JoinInquiry {
  id        String   @id @default(cuid())
  name      String
  contact   String
  message   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isRead, createdAt])
  @@map("join_inquiries")
}
