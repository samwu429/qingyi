# Environment reference template. Copy to .env and fill with real values locally.
# The .env file is gitignored; never commit real credentials.
# 环境变量引用模板。请复制为 .env 并在本地填入真实值。
# .env 已被 gitignore；切勿提交真实凭证。

# PostgreSQL connection string (Render Postgres provides this value).
# PostgreSQL 连接串（Render Postgres 会提供该值）。
DATABASE_URL="postgresql://user:password@host:5432/qingyi?schema=public"

# Secret used to sign admin session tokens. Must be at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 用于签名后台会话令牌的密钥，至少 32 个字符。
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# Initial administrator credentials consumed only by the seed script.
# 仅供 seed 脚本使用的初始管理员凭证。
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-strong-password"

# Public site origin (no trailing slash). Used for canonical URLs / sharing cards,
# and for admin AI screenshot intake (Groq fetches images via this public URL).
# 站点公开地址（不要末尾斜杠）：规范链接 / 分享卡片，以及后台 AI 识图
#（Groq 经此公网地址拉取截图，避免巨型 base64）。
NEXT_PUBLIC_SITE_URL="https://qingyi.onrender.com"

# Optional Cloudinary unsigned upload. When set, admin image uploads prefer
# Cloudinary. When blank, uploads are stored in Postgres and served from
# /api/media/:id (survives Render redeploys). Prefer leaving blank for China
# visitors — Cloudinary can be slow or flaky from mainland networks.
# 可选 Cloudinary 无签名上传。配置后后台优先走 Cloudinary；
# 未配置时图片写入 Postgres，经 /api/media/:id 提供（重新部署也不丢）。
# 面向国内访客时建议留空：Cloudinary 在大陆网络上可能偏慢或不稳定。
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# Groq API key powering the on-site chat assistant and admin AI console
# (https://console.groq.com/keys). Leave blank to disable AI features.
# Keep this secret out of version control.
# 驱动站内客服与后台 AI 助手的 Groq API Key。留空则关闭 AI。切勿提交真实密钥。
GROQ_API_KEY=""
# Optional model override for the public chat widget.
# 前台客服可选模型覆盖。
GROQ_MODEL="llama-3.3-70b-versatile"
# Multimodal model for admin screenshot → DB workflows (vision + tools).
# 后台截图入库用的多模态模型（视觉 + 工具调用）。
GROQ_VISION_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
# Optional override for admin tool loop when no images are attached.
# 无图片时后台工具循环的可选模型覆盖。
GROQ_ADMIN_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
